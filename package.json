{
  "name": "@auto-repair-shop/auth-lambda",
  "version": "1.0.0",
  "description": "CPF-based authentication Lambda function for Auto Repair Shop",
  "main": "dist/handlers/auth-handler.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "zip": "cd dist && zip -r ../lambda.zip . && cd .. && zip -r lambda.zip node_modules -x 'node_modules/@types/*' 'node_modules/typescript/*' 'node_modules/eslint/*' 'node_modules/jest/*' 'node_modules/ts-jest/*'",
    "package": "npm run build && npm run zip",
    "clean": "rm -rf dist lambda.zip"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
